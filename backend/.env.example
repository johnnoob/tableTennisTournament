# ==============================================================================
# backend/.env.example — 後端環境變數說明範本
# ==============================================================================
# 使用說明：
#   1. 本地開發：複製此檔為 backend/.env，填入真實值
#   2. 正式部署 (Render/Railway)：在平台後台「Environment Variables」直接設定，
#      不需要上傳 .env 檔案
# ==============================================================================

# ── 應用程式環境 ─────────────────────────────────────────────────────────────
# 本地開發設 "development"，正式環境設 "production"
APP_ENV=development

# ── 資料庫 ─────────────────────────────────────────────────────────────────
# 本地開發 (SQLite)：
#   DATABASE_URL=sqlite:///arena.db
# 正式環境 (Neon PostgreSQL)：
#   DATABASE_URL=postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgresql://neondb_owner:CHANGE_ME@ep-xxxx.ap-southeast-1.aws.neon.tech/arena_db?sslmode=require

# ── Session 安全密鑰 (用於 Starlette SessionMiddleware) ──────────────────────
# 請使用 `openssl rand -hex 32` 生成隨機字串，並在正式環境替換
SECRET_KEY=your-starlette-session-secret-key-at-least-32-chars

# ── JWT 身份驗證 ──────────────────────────────────────────────────────────────
# 請使用 `openssl rand -hex 32` 生成，正式環境與開發環境請使用不同的 Key
JWT_SECRET_KEY=your-jwt-signing-secret-key-please-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS 允許來源 ─────────────────────────────────────────────────────────────
# 本地開發：
#   ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 正式環境：替換為真實部署網址
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 在 Google Cloud Console 取得：https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ── 前後端 URL（用於 OAuth callback 與 Cookie 設定）──────────────────────────
# 本地開發：
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
# 正式部署（範例）：
#   FRONTEND_URL=https://your-app.vercel.app
#   BACKEND_URL=https://your-api.onrender.com

# ── Cloudinary（圖片上傳）────────────────────────────────────────────────────
# 在 Cloudinary Dashboard 取得：https://cloudinary.com/
CLOUDINARY_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── 其他 ──────────────────────────────────────────────────────────────────────
ENV_STATUS=development
TEST_MODE_SCHEDULER=False
