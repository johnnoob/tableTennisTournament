# ==============================================================================
# .env.production — 前端正式部署環境變數
# 執行 `npm run build` 時 Vite 自動載入此檔
# ==============================================================================

# API 指向正式後端伺服器（替換為真實的 Render/Railway 後端網址）
# 若前後端部署在同一個網域，可用相對路徑 /api 讓後端 Nginx 做 proxy
VITE_API_BASE_URL=https://your-api.onrender.com/api

# 應用程式環境識別
VITE_APP_ENV=production