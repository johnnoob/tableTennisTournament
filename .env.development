# ==============================================================================
# .env.development — 前端本地開發環境變數
# 執行 `npm run dev` 時 Vite 自動載入此檔
# ==============================================================================

# API 指向本地後端伺服器
VITE_API_BASE_URL=http://localhost:8000/api

# 應用程式環境識別（可在前端 JS 中讀取：import.meta.env.VITE_APP_ENV）
VITE_APP_ENV=development
